# To-do List App

def add_task(my_tasks):

    task=input("Enter Your Task: ")
    if task in my_tasks:
        print("Task Already Added!")
    else:
        my_tasks.append(task)
        print("Task Added Successfully!")
        return

def view_task(my_tasks):

    if not my_tasks:
        print("No Task exist Right Now!")
    else:
        print("=== Current Tasks Are ===")
        for i, task in enumerate(my_tasks, start=1):
            print(f"{i}. {task}")

def delete_task(my_tasks):

    if not my_tasks:
        print("No Task exist Right Now!")
    else:
        task=input("Enter Task to Delete: ")
        if task not in my_tasks:
            print("No such task exists..")
            return
        
        my_tasks.remove(task)
        print("Task Deleted Successfully!")
        return

def update_task(my_tasks):
    if not my_tasks:
        print("No Task exists Right Now!")
    else:
        task=input("Enter Task name to change or update: ")
        updated_task=input("Enter New Task: ")

        if task not in my_tasks:
            print("No such task exists..")
            return
        
        index = my_tasks.index(task)
        my_tasks[index] = updated_task
        print("Task Updated Successfully!")
        return

my_tasks=[]

print(f"{'='*10} TO-DO List App {'='*10}")

while True:
    print("\n1 ==> Add Task")
    print("2 ==> View Tasks")
    print("3 ==> Delete Task")
    print("4 ==> Update Task")
    print("5 ==> Exit")

    choice=input("Enter Your Choice(1-5):")

    if choice=="1":
        add_task(my_tasks)

    elif choice=="2":
        view_task(my_tasks)

    elif choice=="3":
        delete_task(my_tasks)

    elif choice=="4":
        update_task(my_tasks)

    elif choice=="5":
        print("Good Bye 🙌!")
        break

    else:
        print("Please Enter Valid Input! Try Again!")
